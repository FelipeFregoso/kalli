Options -Indexes
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on [OR]
  RewriteCond %{HTTP_HOST} !^kalli\.mayartestudio\.com$ [NC]
  RewriteRule ^ https://kalli.mayartestudio.com%{REQUEST_URI} [L,R=301]
</IfModule>

<FilesMatch "^(contact-config\.php|\.env|\.git|composer\.(json|lock))$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  <FilesMatch "\.(css|js|svg|webp|avif|jpg|jpeg|png|gif|ico)$">
    Header set Cache-Control "public, max-age=2592000, immutable"
  </FilesMatch>
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css text/javascript application/javascript application/json image/svg+xml
</IfModule>
